// ══════════════════════════════════════════
// APP
// ══════════════════════════════════════════
const ALL_CATS = ["All", ...Array.from(new Set(BANK.map(q=>q.cat)))];

let roundSize = 15;
let selectedCat = "All";
let activeQs = [];
let current = 0;
let answered = {};
let score = 0;

function shuffle(arr){ return [...arr].sort(()=>Math.random()-.5); }
function getPool(){ return selectedCat==="All" ? BANK : BANK.filter(q=>q.cat===selectedCat); }

function buildRound(){
  const pool = getPool();
  const n = Math.min(roundSize, pool.length);
  activeQs = shuffle(pool).slice(0,n);
  current=0; answered={}; score=0;
}

// ── HOME ──────────────────────────────────────────────────────────────────────
(function initHome(){
  document.querySelectorAll('#size-pills .pill').forEach(p=>{
    p.addEventListener('click',()=>{
      document.querySelectorAll('#size-pills .pill').forEach(x=>x.classList.remove('sel'));
      p.classList.add('sel');
      roundSize=parseInt(p.dataset.val);
    });
  });
  const cp=document.getElementById('cat-pills');
  ALL_CATS.forEach(c=>{
    const b=document.createElement('button');
    b.className='pill'+(c==="All"?' sel':'');
    b.textContent=c;
    b.addEventListener('click',()=>{
      document.querySelectorAll('#cat-pills .pill').forEach(x=>x.classList.remove('sel'));
      b.classList.add('sel');
      selectedCat=c;
    });
    cp.appendChild(b);
  });
})();

function goHome(){ show('screen-home'); }

// ── QUIZ ──────────────────────────────────────────────────────────────────────
function startQuiz(){ buildRound(); show('screen-quiz'); renderQ(); }

function renderQ(){
  const q=activeQs[current];
  const total=activeQs.length;
  document.getElementById('prog-label').textContent=`Question ${current+1} of ${total}`;
  document.getElementById('cat-label').textContent=q.cat;
  document.getElementById('progress-fill').style.width=Math.round((current/total)*100)+'%';
  document.getElementById('score-pill').textContent='+'+score;
  document.getElementById('q-category').textContent=q.cat;
  const sc=document.getElementById('q-scenario');
  if(q.scenario){sc.textContent='📋 '+q.scenario;sc.style.display='block';}
  else{sc.style.display='none';}
  document.getElementById('q-text').textContent=q.q;
  const optsEl=document.getElementById('options');
  optsEl.innerHTML='';
  const isAnswered=answered[q.id]!==undefined;
  q.opts.forEach((opt,i)=>{
    const btn=document.createElement('button');
    btn.className='opt';
    btn.disabled=isAnswered;
    if(isAnswered){
      if(i===q.ans) btn.classList.add('correct');
      else if(i===answered[q.id]) btn.classList.add('wrong');
    }
    btn.innerHTML=`<span class="opt-letter">${String.fromCharCode(65+i)}.</span><span>${opt}</span>`;
    btn.addEventListener('click',()=>selectAnswer(i));
    optsEl.appendChild(btn);
  });
  const expEl=document.getElementById('explanation');
  if(isAnswered){
    const right=answered[q.id]===q.ans;
    expEl.innerHTML=`<strong>${right?'✓ Correct — ':'✗ Incorrect — '}</strong>${q.exp}`;
    expEl.className='explanation'+(right?'':' wrong-exp');
    expEl.style.display='block';
  } else { expEl.style.display='none'; }
  document.getElementById('btn-prev').disabled=current===0;
  document.getElementById('btn-next').textContent=current+1===total?'See Results →':'Next →';
}

function selectAnswer(i){
  const q=activeQs[current];
  if(answered[q.id]!==undefined) return;
  answered[q.id]=i;
  if(i===q.ans) score++;
  renderQ();
}
function nextQ(){ if(current+1>=activeQs.length){showResults();return;} current++;renderQ(); }
function prevQ(){ if(current>0){current--;renderQ();} }

// ── RESULTS ───────────────────────────────────────────────────────────────────
function showResults(){
  show('screen-results');
  const total=activeQs.length;
  const pct=Math.round((score/total)*100);
  document.getElementById('res-pct').textContent=pct+'%';
  document.getElementById('res-fraction').textContent=`${score} of ${total} correct`;
  document.getElementById('res-correct').textContent=score;
  document.getElementById('res-wrong').textContent=total-score;
  document.getElementById('res-total').textContent=total;
  const msgs=['💡 Keep working through the material. Try filtering by category to drill weak areas.','📖 Getting there. Review the explanations for missed questions.','📚 Solid performance. Focus on the categories where you struggled.','🏛️ Excellent. You have a strong command of AP Gov Units 1 & 2.'];
  document.getElementById('res-msg').textContent=pct>=88?msgs[3]:pct>=72?msgs[2]:pct>=55?msgs[1]:msgs[0];

  // category breakdown
  const catMap={};
  activeQs.forEach(q=>{
    if(!catMap[q.cat]) catMap[q.cat]={c:0,t:0};
    catMap[q.cat].t++;
    if(answered[q.id]===q.ans) catMap[q.cat].c++;
  });

  let html='';
  if(Object.keys(catMap).length>1){
    html+='<div class="review-section-title">Category Breakdown</div><div class="cat-grid">';
    Object.entries(catMap).forEach(([cat,{c,t}])=>{
      const p=Math.round((c/t)*100);
      const col=p>=80?'var(--green)':p>=55?'var(--gold)':'var(--red)';
      html+=`<div class="cat-card"><div class="cat-pct" style="color:${col}">${p}%</div><div class="cat-name">${cat}<br><span style="color:var(--text)">${c}/${t} correct</span></div></div>`;
    });
    html+='</div>';
  }

  const missed=activeQs.filter(q=>answered[q.id]!==undefined&&answered[q.id]!==q.ans);
  if(missed.length>0){
    html+='<div class="review-section-title">Missed Questions — Review</div><div class="review-list">';
    missed.forEach(q=>{
      html+=`<div class="review-item">
        <div class="review-q">${q.q}</div>
        <div class="review-a">Your answer: <span style="color:var(--red)">${q.opts[answered[q.id]]}</span></div>
        <div class="review-a">Correct: <span style="color:var(--green)">${q.opts[q.ans]}</span></div>
        <div class="review-exp">${q.exp}</div>
      </div>`;
    });
    html+='</div>';
  }
  document.getElementById('review-section').innerHTML=html;
}

// ── UTIL ──────────────────────────────────────────────────────────────────────
function show(id){
  ['screen-home','screen-quiz','screen-results'].forEach(s=>{
    const el=document.getElementById(s);
    el.classList.remove('active'); el.style.display='none';
  });
  const el=document.getElementById(id);
  el.style.display='flex'; el.classList.add('active');
  window.scrollTo(0,0);
}
</script>
